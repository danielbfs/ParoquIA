rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'danielbfs@gmail.com' ||
        get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role == 'admin'
      );
    }

    function isAuthorized() {
      return isSignedIn() && (
        request.auth.token.email == 'danielbfs@gmail.com' ||
        exists(/databases/$(database)/documents/authorized_emails/$(request.auth.token.email)) ||
        get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.isAuthorized == true
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Proxy for Authorized Emails Management (Admin Only)
    match /authorized_emails/{email} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Connection Test
    match /test/connection {
      allow read: if isSignedIn();
    }

    // Profiles Rules
    match /profiles/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == userId && !("role" in incoming()));
    }

    // Config Rules
    match /config/{configId} {
      allow read: if isAuthorized();
      allow write: if isAdmin();
    }

    // Parish Rules
    match /parishes/{parishId} {
      allow read: if isAuthorized();
      allow write: if isAdmin();
    }

    // Parishioner Rules
    match /parishioners/{parishionerId} {
      allow read: if isAuthorized();
      allow create: if isAuthorized() && isValidParishioner(incoming());
      allow update: if isAuthorized() && (isAdmin() || isValidParishioner(incoming()));
      allow delete: if isAdmin();
    }

    function isValidParishioner(data) {
      return data.keys().hasAll(['name']) &&
             data.name is string && data.name.size() <= 200;
    }

    // Message Rules
    match /messages/{messageId} {
      allow read: if isAuthorized();
      allow create: if isAuthorized() && isValidMessage(incoming());
      allow update: if isAuthorized() && isValidMessage(incoming());
      allow delete: if isAdmin();
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['platform', 'sender', 'content', 'status', 'role', 'createdAt']) &&
             data.platform in ['whatsapp', 'instagram', 'email'] &&
             data.status in ['pending', 'processed', 'responded'] &&
             data.role in ['user', 'ai', 'system'] &&
             data.content is string && data.content.size() <= 5000;
    }

    // Conversation Rules
    match /conversations/{convId} {
      allow read: if isAuthorized();
      allow create: if isAuthorized() && isValidConversation(incoming());
      allow update: if isAuthorized() && isValidConversation(incoming());
      allow delete: if isAdmin();
    }

    function isValidConversation(data) {
      return data.keys().hasAll(['sender', 'isAiEnabled', 'lastMessageAt']) &&
             data.sender is string && data.sender.size() <= 200 &&
             data.isAiEnabled is bool;
    }

    // Critique Rules
    match /critiques/{critiqueId} {
      allow read: if isAuthorized();
      allow create: if isAuthorized() && isValidCritique(incoming());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    function isValidCritique(data) {
      return data.keys().hasAll(['messageId', 'critique', 'createdAt']) &&
             isValidId(data.messageId) &&
             data.critique is string && data.critique.size() <= 5000;
    }

    // Transaction Rules
    match /transactions/{transactionId} {
      allow read: if isAuthorized();
      allow create: if isAuthorized() && isValidTransaction(incoming());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['type', 'amount', 'date']) &&
             data.type in ['tithe', 'offering'] &&
             data.amount is number && data.amount > 0;
    }

    // Event Rules
    match /events/{eventId} {
      allow read: if isAuthorized();
      allow create: if isAuthorized() && isValidEvent(incoming());
      allow update: if isAuthorized() && (isAdmin() || isValidEvent(incoming()));
      allow delete: if isAdmin();
    }

    function isValidEvent(data) {
      return data.keys().hasAll(['title', 'date', 'location']) &&
             data.title is string && data.title.size() <= 200;
    }
  }
}
